{
  "services": [
    {
      "type": "web",
      "name": "nutralyze",
      "runtime": "docker",
      "dockerfilePath": "./Dockerfile",
      "envVars": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "PORT",
          "value": "8080"
        },
        {
          "key": "MONGO_URI",
          "sync": false
        },
        {
          "key": "JWT_SECRET",
          "sync": false
        },
        {
          "key": "GEMINI_API_KEY",
          "sync": false
        },
        {
          "key": "GOOGLE_API_KEY",
          "sync": false
        },
        {
          "key": "GROQ_API_KEY",
          "sync": false
        },
        {
          "key": "CORS_ORIGINS",
          "sync": false
        },
        {
          "key": "VITE_API_URL",
          "sync": false
        },
        {
          "key": "VITE_BACKEND_URL",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_API_KEY",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_AUTH_DOMAIN",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_PROJECT_ID",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_STORAGE_BUCKET",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_MESSAGING_SENDER_ID",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_APP_ID",
          "sync": false
        },
        {
          "key": "VITE_FIREBASE_MEASUREMENT_ID",
          "sync": false
        },
        {
          "key": "VITE_AI_MODEL_URL",
          "value": "https://nutrivision-ai.onrender.com"
        },
        {
          "key": "VITE_GEMINI_API_KEY",
          "sync": false
        }
      ]
    }
  ]
}